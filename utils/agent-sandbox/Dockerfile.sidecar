# Sidecar proxy for the agent sandbox (Phase B.1).
#
# Runs mitmproxy as the L7 egress policy enforcement point, OUTSIDE the agent
# container. Connected to both an internal Docker network (agent-facing) and the
# default bridge (internet-facing). The agent container's only route to the
# internet goes through this sidecar — even if the agent gains root and flushes
# iptables inside its own container, the sidecar's enforcement is unreachable.
#
# This closes the last residual risk from Phase B (in-container proxy): the
# iptables-flush escape.

FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        iptables \
        iproute2 \
        procps \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# mitmproxy — pinned for reproducibility (matches Phase B).
RUN pip install --no-cache-dir mitmproxy==11.1.3

COPY egress-policy.py /opt/egress-policy.py
COPY firewall-domains.txt /etc/firewall-domains.txt
COPY --chmod=0755 sidecar-entrypoint.sh /usr/local/bin/sidecar-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/sidecar-entrypoint.sh"]
