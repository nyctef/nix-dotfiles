# Sidecar proxy for the agent sandbox (Phase B.1).
#
# Runs mitmproxy as a forward (explicit) proxy on an --internal Docker network.
# The agent container routes HTTP(S) through this proxy via HTTP_PROXY env vars.
# Docker's --internal network provides mandatory enforcement: even if the agent
# ignores the proxy, packets with non-subnet destination IPs are DROPped by
# Docker's host-level iptables. No iptables, ip_forward, or NET_ADMIN needed.

FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        procps \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# mitmproxy — pinned for reproducibility (matches Phase B).
RUN pip install --no-cache-dir mitmproxy==11.1.3

COPY egress-policy.py /opt/egress-policy.py
COPY firewall-domains.txt /etc/firewall-domains.txt
COPY --chmod=0755 sidecar-entrypoint.sh /usr/local/bin/sidecar-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/sidecar-entrypoint.sh"]
